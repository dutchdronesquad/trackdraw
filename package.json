{
  "name": "trackdraw",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env dev",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "migrate:local": "wrangler d1 migrations apply DB --local --env dev",
    "migrate:up:dev": "wrangler d1 migrations apply DB --remote --env dev",
    "migrate:up:production": "wrangler d1 migrations apply DB --remote",
    "migrate:create": "wrangler d1 migrations create DB",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type": "next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.0.0",
    "immer": "^11.0.0",
    "jspdf": "^4.0.0",
    "konva": "^10.0.2",
    "lucide-react": "^1.0.0",
    "lz-string": "^1.5.0",
    "nanoid": "^5.1.6",
    "next": "^16.1.0",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.2.3",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.0",
    "three": "^0.183.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.0.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.0",
    "eslint-config-prettier": "^10.1.8",
    "node-pg-migrate": "^8.0.3",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "wrangler": "^4.78.0"
  }
}
