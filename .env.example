# Used by node-pg-migrate for local development migrations.
DATABASE_URL_DEVELOPMENT=postgres://username:password@0.0.0.0:5432/database_name

# Copy this same value into `.env.local` and `.dev.vars` for local OpenNext + Wrangler preview.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://username:password@0.0.0.0:5432/database_name

# Optional local app environment hint.
NEXT_PUBLIC_APP_ENV=development
TRACKDRAW_RUNTIME_ENV=development
TRACKDRAW_DB_ENV=development
